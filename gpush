#!/usr/bin/env bash

set -euo pipefail

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
NC='\033[0m'

FORCE=0

usage() {
    cat <<EOF
Usage:
  $(basename "$0") [-f|--force] <commit message>

Options:
  -f, --force   Skip confirmation prompt and immediately commit & push
  --help        Show this help message

Example:
  $(basename "$0") "fix: update login flow"
  $(basename "$0") -f "fix: hotfix production issue"
EOF
}

# Parse args
ARGS=()
while [[ $# -gt 0 ]]; do
    case "$1" in
        -f|--force)
            FORCE=1
            shift
            ;;
        --help)
            usage
            exit 0
            ;;
        *)
            ARGS+=("$1")
            shift
            ;;
    esac
done

if [ ${#ARGS[@]} -eq 0 ]; then
    usage
    exit 1
fi

COMMIT_MESSAGE="${ARGS[*]}"

# Ensure we're in a git repo
git rev-parse --is-inside-work-tree >/dev/null 2>&1 || {
    echo -e "${RED}Error:${NC} Not inside a git repository."
    exit 1
}

BRANCH=$(git branch --show-current)

# Determine upstream
if git rev-parse --abbrev-ref @{u} >/dev/null 2>&1; then
    UPSTREAM=$(git rev-parse --abbrev-ref @{u})
else
    UPSTREAM="(no upstream configured)"
fi

# Check for changes
if git diff --quiet && git diff --cached --quiet; then
    echo -e "${YELLOW}Nothing to commit.${NC}"
    exit 0
fi

echo
echo -e "${BOLD}Git Commit & Push${NC}"
echo "──────────────────────────────────────────"
echo -e "${BLUE}Branch:${NC}         $BRANCH"
echo -e "${BLUE}Push target:${NC}    $UPSTREAM"
echo -e "${BLUE}Commit message:${NC}"
echo "  \"$COMMIT_MESSAGE\""
echo

echo -e "${BLUE}Changes:${NC}"
git status --short
echo

if [[ "$FORCE" -eq 0 ]]; then
    read -rp "Continue? [y/N]: " CONFIRM

    case "$CONFIRM" in
        [yY]|[yY][eE][sS])
            ;;
        *)
            echo "Cancelled."
            exit 0
            ;;
    esac
fi

echo
echo -e "${YELLOW}Staging files...${NC}"
git add .

echo -e "${YELLOW}Creating commit...${NC}"
git commit -m "$COMMIT_MESSAGE"

echo -e "${YELLOW}Pushing...${NC}"
git push

echo
echo -e "${GREEN}✓ Successfully committed and pushed!${NC}"
echo -e "${GREEN}Branch:${NC} $BRANCH"
echo -e "${GREEN}Message:${NC} \"$COMMIT_MESSAGE\""
